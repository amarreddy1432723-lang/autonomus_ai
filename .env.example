# ═══════════════════════════════════════════════════════════════════════════
#  Autonomus AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit the real .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgrespassword@localhost:5432/my_ai_db
POSTGRES_IMAGE=pgvector/pgvector:pg16
APP_ENV=local
ALLOW_DEMO_USER=true
ALLOW_DEV_AUTH_FALLBACK=true
JWT_SECRET=supersecretkeyforlocaldevelopmentonlychangeinprod!
APP_ENCRYPTION_KEY=local-dev-field-encryption-key-change-in-prod
REDIS_HOST=localhost
REDIS_PORT=6379
# Render/managed Redis can provide a single URL. When set, REDIS_URL wins.
# REDIS_URL=redis://default:password@host:6379
AGENT_PORT=8003
AUTH_PORT=8001
GOALS_PORT=8002
NEXT_PUBLIC_AUTH_URL=http://localhost:8001
NEXT_PUBLIC_GOALS_URL=http://localhost:8002
NEXT_PUBLIC_AGENT_URL=http://localhost:8003
NEXT_PUBLIC_REQUIRE_AUTH=false

# ── Clerk Auth ────────────────────────────────────────────────────────────
# Production frontend uses Clerk session tokens.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# CLERK_ISSUER=https://your-clerk-frontend-api.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=

# ── File Storage (S3/R2-compatible) ──────────────────────────────────────
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_LOCAL_DIR=uploads
# FILE_STORAGE_PROVIDER=s3
# S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=autonomus-ai-files
# S3_ACCESS_KEY_ID=<r2-or-s3-access-key>
# S3_SECRET_ACCESS_KEY=<r2-or-s3-secret>
# S3_REGION=auto

# ═══════════════════════════════════════════════════════════════════════════
#  LLM PROVIDER CONFIGURATION
#  Set LLM_PROVIDER to one of:
#    autonomus  — your own OpenAI-compatible Autonomus AI model endpoint
#    mock       — no API key needed, fully local (default for dev)
#    openai     — OpenAI GPT-4o, GPT-4o-mini, etc.
#    anthropic  — Anthropic Claude models
#    google     — Google Gemini models
#    groq       — Groq hosted inference (fast, has free tier)
#    ollama     — Local self-hosted models via Ollama
#    custom     — Any OpenAI-compatible endpoint (vLLM, LM Studio, Jan, LocalAI)
# ═══════════════════════════════════════════════════════════════════════════

# ── Active Provider ───────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_MODEL=autonomus-ai-v1

# ── Per-Role Model Overrides (optional) ──────────────────────────────────
# If unset, falls back to LLM_MODEL above.
# APPROVAL_LLM_MODEL=gpt-4o              # Use stronger model for risk decisions
# EXTRACTION_LLM_MODEL=gpt-4o-mini      # Cheaper model for memory extraction
# FALLBACK_LLM_PROVIDER=groq             # Private operational fallback, never shown in UI
# FALLBACK_LLM_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════════════════
#  EMBEDDING PROVIDER
#  Set EMBEDDING_PROVIDER to one of:
#    mock         — deterministic seeded random (default for dev)
#    openai       — text-embedding-3-small / ada-002
#    google       — text-embedding-004
#    ollama       — nomic-embed-text, mxbai-embed-large
#    huggingface  — all-MiniLM-L6-v2 (local)
#
#  ⚠️  Changing embedding providers changes vector dimensions.
#      Run a DB migration and re-embed all memories if you switch.
# ═══════════════════════════════════════════════════════════════════════════

EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small

# ═══════════════════════════════════════════════════════════════════════════
#  API KEYS
#  Only fill in keys for the provider you are using.
# ═══════════════════════════════════════════════════════════════════════════

# OpenAI (provider=openai)
OPENAI_API_KEY=mock-openai-key-for-local-dev-only

# Anthropic Claude (provider=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (provider=google, embedding_provider=google)
# GOOGLE_API_KEY=AIza...

# Groq (provider=groq) — free tier available at console.groq.com
# GROQ_API_KEY=gsk_...

# Web search tool
SERPER_API_KEY=mock-serper-key-for-local-dev-only

# ═══════════════════════════════════════════════════════════════════════════
#  PRODUCTION LAUNCH MINIMUMS
#  Set these outside git before inviting users:
#    APP_ENV=production
#    ALLOW_DEMO_USER=false
#    ALLOW_DEV_AUTH_FALLBACK=false
#    NEXT_PUBLIC_REQUIRE_AUTH=true
#    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<clerk publishable key>
#    CLERK_SECRET_KEY=<clerk secret key>
#    CLERK_ISSUER=<clerk issuer>
#    FILE_STORAGE_PROVIDER=s3
#    S3_ENDPOINT_URL/S3_BUCKET/S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY=<object storage>
#    DATABASE_URL=<managed postgres url>
#    REDIS_URL=<managed redis url> or REDIS_HOST=<managed redis host>
#    JWT_SECRET=<strong random secret>
#    APP_ENCRYPTION_KEY=<strong random encryption secret>
#    LLM_PROVIDER=autonomus
#    LLM_MODEL=autonomus-ai-v1
#    AUTONOMUS_LLM_BASE_URL=https://your-autonomus-ai-server.example.com/v1
#    AUTONOMUS_LLM_API_KEY=<your model server key>
#    OPENAI_API_KEY/GROQ_API_KEY/GOOGLE_API_KEY/ANTHROPIC_API_KEY=<real key>
#    SERPER_API_KEY=<real search key>
#    NEXT_PUBLIC_AUTH_URL=https://my-ai-auth.onrender.com
#    NEXT_PUBLIC_GOALS_URL=https://my-ai-goals.onrender.com
#    NEXT_PUBLIC_AGENT_URL=https://my-ai-agent.onrender.com
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
#  LOCAL / CUSTOM INFERENCE SERVERS
# ═══════════════════════════════════════════════════════════════════════════

# Ollama (provider=ollama or embedding_provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Autonomus AI OpenAI-compatible server (provider=autonomus)
# AUTONOMUS_LLM_BASE_URL=http://localhost:8000/v1    # vLLM default
# AUTONOMUS_LLM_API_KEY=not-needed

# Custom OpenAI-compatible server (provider=custom)
# LLM_BASE_URL=http://localhost:8000/v1    # vLLM default
# LLM_BASE_URL=http://localhost:1234/v1    # LM Studio default
# LLM_BASE_URL=http://localhost:1337/v1    # Jan default
# LLM_BASE_URL=http://localhost:8080/v1    # LocalAI default
# LLM_API_KEY=not-needed

# ═══════════════════════════════════════════════════════════════════════════
#  QUICK SETUP EXAMPLES
#
#  1. Zero Cost — Ollama local (Llama 3.1):
#     LLM_PROVIDER=ollama
#     LLM_MODEL=llama3.1:8b
#     EMBEDDING_PROVIDER=ollama
#     EMBEDDING_MODEL=nomic-embed-text
#
#  2. Autonomus AI local vLLM server:
#     LLM_PROVIDER=autonomus
#     LLM_MODEL=autonomus-ai-v1
#     AUTONOMUS_LLM_BASE_URL=http://localhost:8000/v1
#     AUTONOMUS_LLM_API_KEY=not-needed
#
#  3. Internal fallback/testing — Groq (fast inference):
#     LLM_PROVIDER=groq
#     LLM_MODEL=llama-3.1-70b-versatile
#     GROQ_API_KEY=gsk_...
#     EMBEDDING_PROVIDER=openai
#     EMBEDDING_MODEL=text-embedding-3-small
#     OPENAI_API_KEY=sk-...
#
#  4. Production fallback/testing — Claude + OpenAI embeddings:
#     LLM_PROVIDER=anthropic
#     LLM_MODEL=claude-3-5-haiku-20241022
#     APPROVAL_LLM_MODEL=claude-sonnet-4-5
#     ANTHROPIC_API_KEY=sk-ant-...
#     EMBEDDING_PROVIDER=openai
#     EMBEDDING_MODEL=text-embedding-3-small
#     OPENAI_API_KEY=sk-...
#
#  5. Production fallback/testing — Gemini Flash + Gemini embeddings:
#     LLM_PROVIDER=google
#     LLM_MODEL=gemini-1.5-flash
#     APPROVAL_LLM_MODEL=gemini-1.5-pro
#     EMBEDDING_PROVIDER=google
#     EMBEDDING_MODEL=models/text-embedding-004
#     GOOGLE_API_KEY=AIza...
# ═══════════════════════════════════════════════════════════════════════════
