        "central_brain_agent",
        "planner_agent",
        "memory_agent",
        "research_agent",
        "coding_agent",
        "task_agent",
        "scheduler_agent",
        "reflection_agent",
        "execution_agent",
        "approval_agent",
        "learning_agent",
        "notification_agent"
      ]
    },
