# Arceus production/staging provider configuration template.
# Copy values into Railway/GitHub Actions/hosting provider secrets, not into git.

APP_ENV=production
NEXT_PUBLIC_APP_ENV=production
ALLOW_DEMO_USER=false
ALLOW_DEV_AUTH_FALLBACK=false
NEXT_PUBLIC_REQUIRE_AUTH=true

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/arceus
REDIS_URL=redis://default:PASSWORD@HOST:6379/0
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
APP_ENCRYPTION_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

NEXT_PUBLIC_AUTH_URL=https://auth.example.com
NEXT_PUBLIC_GOALS_URL=https://goals.example.com
NEXT_PUBLIC_AGENT_URL=https://api.example.com

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE
CLERK_SECRET_KEY=sk_live_REPLACE
CLERK_ISSUER=https://your-clerk-issuer
CLERK_JWKS_URL=https://your-clerk-issuer/.well-known/jwks.json
CLERK_AUDIENCE=

STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PRICE_STARTER_MONTHLY=price_REPLACE
STRIPE_PRICE_STARTER_ANNUAL=price_REPLACE
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_REPLACE

GITHUB_APP_ID=REPLACE
GITHUB_APP_NAME=Arceus-AI
GITHUB_APP_SLUG=arceus-ai
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=REPLACE
GITHUB_APP_CLIENT_ID=REPLACE
GITHUB_APP_CLIENT_SECRET=REPLACE

SENTRY_DSN=https://REPLACE@sentry.io/PROJECT
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE@sentry.io/PROJECT
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
APP_RELEASE=arceus-code-v1.0.0
NEXT_PUBLIC_APP_RELEASE=arceus-code-v1.0.0

RAILWAY_TOKEN=REPLACE
RAILWAY_PROJECT=REPLACE
RAILWAY_SERVICE=REPLACE
SMOKE_BACKEND_URL=https://api.example.com
SMOKE_FRONTEND_URL=https://app.example.com
SMOKE_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000

WIN_CSC_LINK=REPLACE
WIN_CSC_KEY_PASSWORD=REPLACE
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=REPLACE
APPLE_TEAM_ID=REPLACE

ARCEUS_RELEASE_VERSION=arceus-code-v1.0.0
ARCEUS_RELEASE_SIGNED=true
ARCEUS_RELEASE_NOTES_URL=https://github.com/arceus-ai/arceus-code/releases/tag/arceus-code-v1.0.0
ARCEUS_UPDATE_FEED_URL=https://github.com/arceus-ai/arceus-code/releases/latest
