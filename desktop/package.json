{
  "name": "nexus-desktop-os",
  "version": "1.0.0",
  "description": "NEXUS AI Standalone Desktop OS Workspace",
  "main": "main.js",
  "bin": {
    "nexus": "./cli.js"
  },
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . \"NEXUS OS\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "dist": "electron-builder"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.nexus.desktop.os",
    "productName": "NEXUS OS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
