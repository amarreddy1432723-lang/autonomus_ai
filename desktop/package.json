{
  "name": "arceus-desktop-os",
  "version": "1.0.0",
  "description": "Arceus AI Standalone Desktop OS Workspace",
  "main": "main.js",
  "bin": {
    "arceus": "./cli.js",
    "nexus": "./cli.js"
  },
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . \"Arceus Code\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "dist": "electron-builder"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.3.9"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "dev.arceus.code",
    "productName": "Arceus Code",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "publisherName": "Arceus",
      "signAndEditExecutable": true,
      "certificateFile": "${env.WIN_CSC_LINK}",
      "certificatePassword": "${env.WIN_CSC_KEY_PASSWORD}",
      "certificateSubjectName": "${env.WINDOWS_CERTIFICATE_SUBJECT_NAME}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "arceus-ai",
        "repo": "arceus-code",
        "releaseType": "release"
      }
    ]
  }
}
